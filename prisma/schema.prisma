generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  matric    String?
  email     String   @unique
  password  String
  role      String   @default("student")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chatSessions    ChatSession[]
  messages        Message[]
  moodEntries     MoodEntry[]
  weeklyInsights  WeeklyInsight[]
}


model ChatSession {
  id        String    @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  userId    String
  createdAt DateTime @default(now())

  session  ChatSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis MessageAnalysis?
}


model MoodEntry {
  id          String   @id @default(cuid())
  userId      String
  // Original field kept as-is for backward compat
  value       Int
  // New structured fields
  moodType    String?  // e.g. HAPPY, SAD, ANXIOUS, ANGRY, CALM, NEUTRAL
  intensity   Int?     // 1-10
  note        String?
  sleepScore  Int?     // 1-10
  energyScore Int?     // 1-10
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}


model MessageAnalysis {
  id         String   @id @default(cuid())
  messageId  String   @unique
  emotion    String   // e.g. ANXIOUS, HAPPY, SAD, ANGRY, NEUTRAL, FEARFUL
  intensity  Int      // 1-10
  riskLevel  String   // LOW | MODERATE | HIGH | CRISIS
  createdAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}


model WeeklyInsight {
  id          String   @id @default(cuid())
  userId      String
  weekStart   DateTime // Monday of the insight week
  content     String   // Human-readable insight text
  tags        String[] // e.g. ["anxiety", "sleep", "stress"]
  generatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
}


model Specialist {
  id                  String   @id @default(cuid())
  name                String
  title               String   // e.g. "Clinical Psychologist"
  specialization      String   // Primary specialization
  bio                 String
  yearsOfExperience   Int
  location            String
  languages           String[] // e.g. ["English", "Yoruba"]
  email               String?
  phone               String?
  imageUrl            String?
  rating              Float    @default(4.5)
  availability        String   // e.g. "Mon-Fri, 9am-5pm"
  consultationType    String   // "virtual" | "physical" | "both"
  tags                String[] // e.g. ["anxiety", "CBT", "trauma"]
  verified            Boolean  @default(false)
  createdAt           DateTime @default(now())

  @@index([specialization])
  @@index([tags])
}
